{
  "name": "@unshared/boolean",
  "type": "module",
  "author": "Stanley Horwood <stanley@hsjm.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shorwood/unshared.git",
    "directory": "packages/boolean"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./Boolean": {
      "import": "./dist/Boolean.js",
      "require": "./dist/Boolean.cjs",
      "types": "./dist/Boolean.d.ts"
    },
    "./and": {
      "import": "./dist/and.js",
      "require": "./dist/and.cjs",
      "types": "./dist/and.d.ts"
    },
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./isBoolean": {
      "import": "./dist/isBoolean.js",
      "require": "./dist/isBoolean.cjs",
      "types": "./dist/isBoolean.d.ts"
    },
    "./isFalse": {
      "import": "./dist/isFalse.js",
      "require": "./dist/isFalse.cjs",
      "types": "./dist/isFalse.d.ts"
    },
    "./isFalsy": {
      "import": "./dist/isFalsy.js",
      "require": "./dist/isFalsy.cjs",
      "types": "./dist/isFalsy.d.ts"
    },
    "./isTrue": {
      "import": "./dist/isTrue.js",
      "require": "./dist/isTrue.cjs",
      "types": "./dist/isTrue.d.ts"
    },
    "./isTruthy": {
      "import": "./dist/isTruthy.js",
      "require": "./dist/isTruthy.cjs",
      "types": "./dist/isTruthy.d.ts"
    },
    "./nand": {
      "import": "./dist/nand.js",
      "require": "./dist/nand.cjs",
      "types": "./dist/nand.d.ts"
    },
    "./nor": {
      "import": "./dist/nor.js",
      "require": "./dist/nor.cjs",
      "types": "./dist/nor.d.ts"
    },
    "./not": {
      "import": "./dist/not.js",
      "require": "./dist/not.cjs",
      "types": "./dist/not.d.ts"
    },
    "./or": {
      "import": "./dist/or.js",
      "require": "./dist/or.cjs",
      "types": "./dist/or.d.ts"
    },
    "./xnor": {
      "import": "./dist/xnor.js",
      "require": "./dist/xnor.cjs",
      "types": "./dist/xnor.d.ts"
    },
    "./xor": {
      "import": "./dist/xor.js",
      "require": "./dist/xor.cjs",
      "types": "./dist/xor.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@unshared/types": "workspace:*"
  }
}
