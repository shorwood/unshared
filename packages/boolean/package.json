    "./and": {
      "import": "./dist/and.js",
      "require": "./dist/and.cjs"
    },
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./isBoolean": {
      "import": "./dist/isBoolean.js",
      "require": "./dist/isBoolean.cjs"
    },
    "./isFalse": {
      "import": "./dist/isFalse.js",
      "require": "./dist/isFalse.cjs"
    },
    "./isFalsy": {
      "import": "./dist/isFalsy.js",
      "require": "./dist/isFalsy.cjs"
    },
    "./isTrue": {
      "import": "./dist/isTrue.js",
      "require": "./dist/isTrue.cjs"
    },
    "./isTruthy": {
      "import": "./dist/isTruthy.js",
      "require": "./dist/isTruthy.cjs"
    },
    "./nand": {
      "import": "./dist/nand.js",
      "require": "./dist/nand.cjs"
    },
    "./nor": {
      "import": "./dist/nor.js",
      "require": "./dist/nor.cjs"
    },
    "./not": {
      "import": "./dist/not.js",
      "require": "./dist/not.cjs"
    },
    "./or": {
      "import": "./dist/or.js",
      "require": "./dist/or.cjs"
    },
    "./xnor": {
      "import": "./dist/xnor.js",
      "require": "./dist/xnor.cjs"
    },
    "./xor": {
      "import": "./dist/xor.js",
      "require": "./dist/xor.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@unshared/types": "workspace:1.0.0"
  }
