{
  "name": "@unshared/boolean",
  "type": "module",
  "author": "Stanley Horwood <stanley@hsjm.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shorwood/unshared.git",
    "directory": "packages/boolean"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    "./Boolean": {
      "import": "./dist/Boolean.js",
