    },
    "./resolveDependencies": {
      "import": "./dist/resolveDependencies.js",
      "require": "./dist/resolveDependencies.cjs"
    },
    "./resolveImport": {
      "import": "./dist/resolveImport.js",
      "require": "./dist/resolveImport.cjs"
    },
    "./resolveModule": {
      "import": "./dist/resolveModule.js",
      "require": "./dist/resolveModule.cjs"
