      "require": "./dist/getPackageJson.cjs"
    },
    "./getPackageJsonPath": {
      "import": "./dist/getPackageJsonPath.js",
      "require": "./dist/getPackageJsonPath.cjs"
    },
    "./getTsConfig": {
      "import": "./dist/getTsConfig.js",
      "require": "./dist/getTsConfig.cjs"
    },
    "./getTsConfigPath": {
      "import": "./dist/getTsConfigPath.js",
      "require": "./dist/getTsConfigPath.cjs"
    },
    "./importEval": {
      "import": "./dist/importEval.js",
      "require": "./dist/importEval.cjs"
    },
    "./importInline": {
      "import": "./dist/importInline.js",
      "require": "./dist/importInline.cjs"
    },
    "./importSafe": {
      "import": "./dist/importSafe.js",
      "require": "./dist/importSafe.cjs"
    },
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
